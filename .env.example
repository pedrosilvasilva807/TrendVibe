# TrendVibe - Environment Variables
# Para desenvolvimento local, crie arquivos .env.local em backend/ e frontend/

# BACKEND ENVIRONMENT (backend/.env.local)
# ==========================================
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
# FRONTEND_URL=http://localhost:5173
# PORT=3001

# FRONTEND ENVIRONMENT (frontend/.env.local)
# ============================================
# VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui
# VITE_API_URL=http://localhost:3001/api

# PARA PRODUCTION (Vercel)
# =========================
# Defina estas variáveis no dashboard Vercel do seu projeto backend:
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, FRONTEND_URL, PORT
# 
# O frontend não precisa de VITE_API_URL pois usará /api (mesmo domínio)
